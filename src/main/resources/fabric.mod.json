{
	"schemaVersion": 1,
	"id": "${id}",
	"version": "${version}",
	"name": "${name}",
	"description": "DyeAddons is a Mod for Hypixel Skyblock.",
	"authors": [
		"Anlg"
	],
	"contact": {
		"homepage": "Coming Soon!",
		"sources": "https://github.com/AlexanderMartens/DyeAddons",
		"issues": "https://github.com/AlexanderMartens/DyeAddons/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/dyeaddons/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "anlg.dyeaddons.DyeAddons",
				"adapter": "kotlin"
			}
		],
		"skyblockapi:imc/pv-profile": [
			"anlg.dyeaddons.api.PvListener::onPvLoad"
		]
	},
	"mixins": [
		"dyeaddons.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "${minecraft}",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	},
	"custom": {
		"modmenu": {
			"update_checker": true
		}
	}
}